---
import { processSteps } from '@/data/process';
---
<section id="process">
  <div class="px-5 sm:px-12 pt-10 sm:pt-[3.75rem] pb-6 sm:pb-9">
    <p class="text-[0.625rem] font-bold tracking-[2px] uppercase text-base-content/40 mb-[0.625rem]">
      How we work together
    </p>
    <h2 class="text-[2.5rem] font-black">Here's what we'll do.</h2>
  </div>
  <div class="grid grid-cols-1 md:grid-cols-2 px-5 sm:px-12 pb-10 sm:pb-[3.75rem]">
    {processSteps.map((step, i) => (
      <div
        class:list={[
          'flex gap-[1.375rem] items-start py-8 sm:py-10 reveal',
          `d${i + 1}`,
          i % 2 === 0 ? 'md:pr-11 md:border-r md:border-base-content/10' : 'md:pl-11',
          i < processSteps.length - 1 ? 'border-b border-base-content/10' : '',
        ]}
      >
        <div aria-hidden="true" class:list={['w-[2.625rem] h-[2.625rem] border-2 flex items-center justify-center text-[0.9375rem] font-extrabold flex-shrink-0 bg-primary', step.accentColor]}>
          {step.number}
        </div>
        <div>
          <h4 class="text-[0.9375rem] font-extrabold mb-2">{step.title}</h4>
          <p class="text-xs text-base-content/60 leading-[1.7]">{step.description}</p>
        </div>
      </div>
    ))}
  </div>
</section>
