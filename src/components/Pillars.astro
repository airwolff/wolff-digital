---
import pillars from '@/data/pillars.json';
const titleColors = ['text-primary', 'text-primary', 'text-primary'];
---
<section class="bg-neutral grid grid-cols-1 sm:grid-cols-3 border-b-2 border-primary">
  {pillars.map((pillar, i) => (
    <div class:list={['pillar reveal', `d${i + 1}`, 'px-6 sm:px-12 py-8 sm:py-10 text-center', i < pillars.length - 1 ? 'sm:border-r border-white/[0.08]' : '']}>
      <h2 class:list={['text-[1.1875rem] font-black mb-[0.625rem]', titleColors[i]]}>{pillar.title}</h2>
      <p class="text-xs text-white/65 leading-[1.7] text-pretty">
        {pillar.description}
      </p>
    </div>
  ))}
</section>
