---
// No props — nav content is static
---
<nav
  id="main-nav"
  aria-label="Main"
  class="bg-base-100 border-b-2 border-neutral px-5 sm:px-12 py-[1.125rem] flex justify-between items-center sticky top-0 z-[100] transition-all duration-300"
>
  <a href="/" class="text-[0.9375rem] font-black tracking-[2px] text-neutral no-underline">
    WOLFF DIGITAL
  </a>
  <!-- Desktop nav -->
  <div class="hidden md:flex gap-7 items-center">
    <a href="#services" class="text-xs text-base-content/65 hover:text-base-content transition-colors">What I do</a>
    <a href="#process" class="text-xs text-base-content/65 hover:text-base-content transition-colors">How we work</a>
    <a href="#about" class="text-xs text-base-content/65 hover:text-base-content transition-colors">About</a>
    <a href="#contact" class="btn btn-primary btn-sm border-2 border-neutral rounded-none text-xs font-bold hover:bg-neutral hover:text-primary transition-colors">
      Get a proposal
    </a>
  </div>
  <!-- Mobile: CTA + hamburger -->
  <div class="flex items-center gap-3 md:hidden">
    <a href="#contact" class="btn btn-primary btn-sm border-2 border-neutral rounded-none text-xs font-bold">
      Get a proposal
    </a>
    <button
      id="hamburger"
      aria-label="Open menu"
      aria-expanded="false"
      class="flex flex-col gap-[5px] p-1"
    >
      <span class="block w-5 h-[2px] bg-neutral transition-all"></span>
      <span class="block w-5 h-[2px] bg-neutral transition-all"></span>
      <span class="block w-5 h-[2px] bg-neutral transition-all"></span>
    </button>
  </div>
</nav>
<!-- Mobile dropdown menu -->
<div
  id="mobile-menu"
  aria-hidden="true"
  class="fixed top-[57px] left-0 right-0 bg-base-100 border-b-2 border-neutral z-[99] px-5 py-4 flex-col gap-4"
  style="display:none;"
>
  <a href="#services" class="text-sm text-base-content/70 hover:text-base-content transition-colors" onclick="document.getElementById('mobile-menu').style.display='none'">What I do</a>
  <a href="#process" class="text-sm text-base-content/70 hover:text-base-content transition-colors" onclick="document.getElementById('mobile-menu').style.display='none'">How we work</a>
  <a href="#about" class="text-sm text-base-content/70 hover:text-base-content transition-colors" onclick="document.getElementById('mobile-menu').style.display='none'">About</a>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const nav = document.getElementById('main-nav') as HTMLElement | null;
    const hamburger = document.getElementById('hamburger') as HTMLButtonElement | null;
    const mobileMenu = document.getElementById('mobile-menu') as HTMLElement | null;

    const closeMenu = () => {
      if (!mobileMenu) return;
      mobileMenu.style.display = 'none';
      mobileMenu.setAttribute('aria-hidden', 'true');
      hamburger?.setAttribute('aria-expanded', 'false');
    };
    const openMenu = () => {
      if (!mobileMenu) return;
      mobileMenu.style.display = 'flex';
      mobileMenu.setAttribute('aria-hidden', 'false');
      hamburger?.setAttribute('aria-expanded', 'true');
    };

    hamburger?.addEventListener('click', () => {
      mobileMenu?.style.display === 'flex' ? closeMenu() : openMenu();
    });

    document.addEventListener('click', (e) => {
      if (nav && !nav.contains(e.target as Node) && mobileMenu?.style.display === 'flex') {
        closeMenu();
      }
    });

    // Scroll blur
    const scrolledBg = 'rgba(247,245,240,0.82)';
    let ticking = false;
    window.addEventListener('scroll', () => {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(() => {
        if (window.scrollY > 40) {
          nav!.style.background = scrolledBg;
          nav!.style.backdropFilter = 'blur(12px)';
          (nav!.style as any).webkitBackdropFilter = 'blur(12px)';
        } else {
          nav!.style.background = '';
          nav!.style.backdropFilter = '';
          (nav!.style as any).webkitBackdropFilter = '';
        }
        ticking = false;
      });
    });
  });
</script>
