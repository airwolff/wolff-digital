---
// No props — nav content is static
---
<nav
  id="main-nav"
  aria-label="Main"
  class="bg-base-100 border-b-2 border-neutral px-12 py-[1.125rem] flex justify-between items-center sticky top-0 z-[100] transition-all duration-300"
>
  <a href="/" class="text-[0.9375rem] font-black tracking-[2px] text-neutral no-underline">
    WOLFF DIGITAL
  </a>
  <div class="flex gap-7 items-center">
    <a href="#services" class="text-xs text-base-content/55 hover:text-base-content transition-colors">What I do</a>
    <a href="#process" class="text-xs text-base-content/55 hover:text-base-content transition-colors">How we work</a>
    <a href="#stack" class="text-xs text-base-content/55 hover:text-base-content transition-colors">The tools</a>
    <a href="#about" class="text-xs text-base-content/55 hover:text-base-content transition-colors">About</a>
    <a href="#contact" class="btn btn-primary btn-sm border-2 border-neutral rounded-none text-xs font-bold hover:bg-neutral hover:text-primary transition-colors">
      Get a proposal
    </a>
  </div>
</nav>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const nav = document.getElementById('main-nav') as HTMLElement | null;
    if (!nav) return;

    // rgba value matches --color-base-100 (#f7f5f0) at 82% opacity
    const scrolledBg = 'rgba(247,245,240,0.82)';

    let ticking = false;
    window.addEventListener('scroll', () => {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(() => {
        if (window.scrollY > 40) {
          nav.style.background = scrolledBg;
          nav.style.backdropFilter = 'blur(12px)';
          (nav.style as any).webkitBackdropFilter = 'blur(12px)';
        } else {
          nav.style.background = '';
          nav.style.backdropFilter = '';
          (nav.style as any).webkitBackdropFilter = '';
        }
        ticking = false;
      });
    });
  });
</script>
