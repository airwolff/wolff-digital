---
// No props
---
<section
  id="hero"
  class="bg-primary border-b-2 border-neutral px-5 sm:px-12 py-16 sm:py-[6.25rem] text-center cursor-crosshair"
>
  <p class="text-[0.6875rem] font-bold tracking-[3px] uppercase text-neutral/50 mb-[1.125rem]">
    Midcoast Maine
  </p>
  <h1 class="text-[2.5rem] sm:text-[3.625rem] font-black text-neutral leading-[1.05] mb-5">
    Your work, done right.<br />
    <span class="text-[#5c4300]">No agency required.</span>
  </h1>
  <p class="text-[1.0625rem] text-neutral/65 max-w-[34rem] mx-auto mb-9 leading-[1.7]">
    A website that loads when you have a weak signal. Emails that get opened.
    I handle the tech — you run your business.
  </p>
  <div class="flex flex-col sm:flex-row gap-[0.875rem] justify-center items-center">
    <a
      href="#contact"
      class="btn btn-neutral rounded-none border-2 border-neutral text-primary text-[0.8125rem] font-extrabold hover:bg-primary hover:text-neutral transition-colors"
    >
      Get a proposal →
    </a>
    <a
      href="#services"
      class="btn btn-outline rounded-none border-2 border-neutral text-neutral text-[0.8125rem] font-bold hover:bg-neutral hover:text-primary transition-colors"
    >
      See my work
    </a>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const hero = document.getElementById('hero') as HTMLElement | null;
    if (!hero) return;

    let currentX = 30, currentY = 60;
    let targetX = 30, targetY = 60;
    let mouseActive = false;

    // Ambient drift — two overlapping sine waves for organic movement
    function ambientPos(t: number) {
      const x = 35 + Math.sin(t * 0.00028) * 22 + Math.sin(t * 0.00071) * 10;
      const y = 50 + Math.cos(t * 0.00035) * 18 + Math.cos(t * 0.00059) * 8;
      return { x, y };
    }

    function setGradient(x: number, y: number) {
      hero.style.background = [
        `radial-gradient(ellipse 70% 65% at ${x}% ${y}%,`,
        `rgba(0,245,184,0.38) 0%,`,
        `rgba(0,225,165,0.14) 38%,`,
        `transparent 68%),`,
        `#ebbb40`,
      ].join(' ');
    }

    function loop(ts: number) {
      if (!mouseActive) {
        const a = ambientPos(ts);
        targetX = a.x;
        targetY = a.y;
      }
      // Lerp — slow catch-up on ambient, faster on mouse
      const speed = mouseActive ? 0.09 : 0.025;
      currentX += (targetX - currentX) * speed;
      currentY += (targetY - currentY) * speed;
      setGradient(currentX, currentY);
      requestAnimationFrame(loop);
    }

    hero.addEventListener('mousemove', (e: MouseEvent) => {
      const rect = hero.getBoundingClientRect();
      targetX = ((e.clientX - rect.left) / rect.width) * 100;
      targetY = ((e.clientY - rect.top) / rect.height) * 100;
      mouseActive = true;
    });

    hero.addEventListener('mouseleave', () => { mouseActive = false; });

    requestAnimationFrame(loop);
  });
</script>
