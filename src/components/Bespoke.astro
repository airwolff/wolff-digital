---
import bespoke from '@/data/bespoke.json';
---
<section class="bg-neutral px-5 sm:px-12 py-10 sm:py-12 border-t-2 border-primary border-b-2 grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-16 items-center">
  <div class="grid grid-cols-2 gap-[0.625rem] order-last md:order-first">
    {bespoke.examples.map((ex, i) => (
      <div class:list={['border border-primary/30 p-[0.875rem] reveal', `d${i + 1}`]}>
        <p class="text-xs font-bold text-primary mb-1">{ex.name}</p>
        <p class="text-[0.6875rem] text-white/60 leading-[1.5]">{ex.desc}</p>
      </div>
    ))}
  </div>
  <div>
    <p class="text-[0.625rem] text-primary font-bold tracking-[2px] uppercase mb-[0.875rem]">
      {bespoke.eyebrow}
    </p>
    <h2 class="text-[1.75rem] font-black text-white leading-[1.2] mb-[0.875rem]">
      {bespoke.headline}
    </h2>
    <p class="text-[0.8125rem] text-white/70 leading-[1.8] text-pretty">
      {bespoke.body}
    </p>
  </div>
</section>
