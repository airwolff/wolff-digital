---
// HoneyBook lead capture — lazy-loaded on scroll to avoid blocking page render
---
<section id="contact" class="bg-primary px-5 sm:px-12 py-14 sm:py-20 text-center border-t-2 border-neutral border-b-2">
  <p class="text-[0.625rem] font-bold tracking-[2px] uppercase text-neutral/70 mb-[0.625rem]">
    Start a project
  </p>
  <h2 class="text-[2rem] sm:text-[2.5rem] font-black mb-[0.625rem]">Let's talk about your project.</h2>
  <p class="text-[0.9375rem] text-neutral/80 mb-2">
    Fill this out — I'll get back to you within one business day.
  </p>
  <p class="text-[0.8125rem] text-neutral/70 mb-9">
    Or email directly: <a href="mailto:hello@wolff-digital.com" class="underline hover:text-neutral transition-colors">hello@wolff-digital.com</a>
  </p>
  <!-- HoneyBook lead capture — script injected lazily when section scrolls into view -->
  <div class="max-w-[33.75rem] mx-auto border-2 border-neutral bg-base-100 p-9 text-left">
    <p class="text-[0.625rem] text-base-content/55 mb-4 tracking-[1px] uppercase">Inquiry form</p>
    <div class="hb-p-688ce3d2b9799f002b9e9c9f-1"></div>
  </div>
</section>

<script is:inline>
  (function () {
    var loaded = false;
    function loadHB() {
      if (loaded) return;
      loaded = true;
      window._HB_ = window._HB_ || {};
      window._HB_.pid = '688ce3d2b9799f002b9e9c9f';
      var t = document.createElement('script');
      t.type = 'text/javascript';
      t.async = true;
      t.src = 'https://widget.honeybook.com/assets_users_production/websiteplacements/placement-controller.min.js';
      document.head.appendChild(t);
    }

    var section = document.getElementById('contact');
    if (!section) return;

    if ('IntersectionObserver' in window) {
      var obs = new IntersectionObserver(function (entries) {
        if (entries[0].isIntersecting) {
          loadHB();
          obs.disconnect();
        }
      }, { rootMargin: '300px' });
      obs.observe(section);
    } else {
      // Fallback for very old browsers
      loadHB();
    }
  })();
</script>
