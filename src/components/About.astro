---
import { Image } from 'astro:assets';
import headshot from '../assets/andy-wolff.jpg';
import about from '@/data/about.json';
---
<section id="about" class="px-5 sm:px-12 py-16 sm:py-24 border-b-2 border-base-content/10 flex flex-col sm:flex-row gap-10 sm:gap-14 items-start sm:items-center reveal">
  <Image
    src={headshot}
    alt="Andy Wolff"
    width={200}
    height={200}
    class="w-[10.5rem] h-[10.5rem] rounded-full border-[3px] border-primary object-cover object-top flex-shrink-0"
  />
  <div>
    <h3 class="text-[1.375rem] sm:text-[1.75rem] font-extrabold mb-3">{about.name}</h3>
    <p class="text-[0.9375rem] text-base-content/80 leading-[1.9] max-w-[40rem] text-pretty">
      {about.bio}
    </p>
  </div>
</section>
