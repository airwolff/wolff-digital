---
import ScrollReveal from '@/components/ScrollReveal.astro';
import '@/styles/global.css';

interface Props {
  title?: string;
  description?: string;
}
const {
  title = 'Wolff Digital — Midcoast Maine Web Design & Development',
  description = 'Web design, development, and email for Midcoast Maine businesses. Built fast. Built to last. No agency required.',
} = Astro.props;

const siteUrl = 'https://wolff-digital.com';
const ogImage = `${siteUrl}/og-image.png`;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: 'Wolff Digital',
  description,
  url: siteUrl,
  founder: { '@type': 'Person', name: 'Andy Wolff' },
  areaServed: { '@type': 'Place', name: 'Midcoast Maine' },
  knowsAbout: ['Web Design', 'Web Development', 'Email Marketing'],
};
---
<!DOCTYPE html>
<html lang="en" data-theme="wolff-digital">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={siteUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <!-- JSON-LD -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800;900&display=swap" onload="this.onload=null;this.rel='stylesheet'" />
    <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800;900&display=swap" /></noscript>
  </head>
  <body class="bg-base-100 font-sans text-base-content">
    <slot />
    <ScrollReveal />
  </body>
</html>
